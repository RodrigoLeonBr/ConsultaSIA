# ============================================
# Consultasia V3 - Configurações de Ambiente
# ============================================

# Conexão com o banco Legado (XAMPP rodando na máquina que hospeda o Docker)
# Em Windows/MacOS Desktop usar 'host.docker.internal'. Em prod/Linux usar IP da interface dock0 ou IP real local.
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=hospital
DB_PASSWORD=senha_bd_producao
DB_NAME=producao

# Testes PHPUnit (MariaDB — banco isolado; ver .env.testing.example)
# DB_DATABASE=producao_test

# Infraestrutura V3
# URL base que o React Web usará para bater na API Síncrona (Ex: IP local da máquina em produção)
VITE_API_URL=http://localhost:3000

# Opcionais (Se quiser sobrescrever mapeamento padrão do Compose)
# API_PORT=3000
# WEB_PORT=8080
